<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
.app { padding: 1rem 0; font-family: var(--font-sans); }
.tabs { display: flex; gap: 0; margin-bottom: 1.5rem; border-bottom: 0.5px solid var(--color-border-tertiary); }
.tab { padding: 8px 16px; font-size: 13px; cursor: pointer; border: none; background: none; color: var(--color-text-secondary); border-bottom: 2px solid transparent; margin-bottom: -1px; }
.tab.active { color: var(--color-text-primary); border-bottom: 2px solid var(--color-text-primary); font-weight: 500; }
.tab:hover:not(.active) { color: var(--color-text-primary); }
.panel { display: none; }
.panel.active { display: block; }
.card { background: var(--color-background-primary); border: 0.5px solid var(--color-border-tertiary); border-radius: var(--border-radius-lg); padding: 1rem 1.25rem; margin-bottom: 12px; overflow-x: auto; }
.metric-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(110px,1fr)); gap: 10px; margin-bottom: 1.5rem; }
.metric { background: var(--color-background-secondary); border-radius: var(--border-radius-md); padding: 0.75rem 1rem; }
.metric-label { font-size: 12px; color: var(--color-text-secondary); margin-bottom: 4px; }
.metric-value { font-size: 22px; font-weight: 500; color: var(--color-text-primary); }
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th { text-align: left; padding: 8px 10px; font-weight: 500; font-size: 12px; color: var(--color-text-secondary); border-bottom: 0.5px solid var(--color-border-tertiary); white-space: nowrap; }
td { padding: 8px 10px; border-bottom: 0.5px solid var(--color-border-tertiary); color: var(--color-text-primary); white-space: nowrap; }
tr:last-child td { border-bottom: none; }
.sec { font-size: 12px; font-weight: 500; color: var(--color-text-secondary); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
.badge { display: inline-block; padding: 2px 8px; border-radius: 20px; font-size: 11px; font-weight: 500; }
.b-blue { background:#E6F1FB; color:#185FA5; }
.b-green { background:#EAF3DE; color:#3B6D11; }
.rank-gold { color:#BA7517; font-weight:500; }
.rank-silver { color:#888780; font-weight:500; }
.rank-bronze { color:#993C1D; font-weight:500; }
input[type=text], input[type=number], select {
  height: 34px; padding: 0 10px; font-size: 13px;
  border: 0.5px solid var(--color-border-secondary);
  border-radius: var(--border-radius-md);
  background: var(--color-background-primary);
  color: var(--color-text-primary);
}
input[type=text]:focus, input[type=number]:focus, select:focus { outline: 2px solid var(--color-border-primary); }
.btn { padding: 6px 14px; font-size: 13px; border: 0.5px solid var(--color-border-secondary); border-radius: var(--border-radius-md); background: transparent; cursor: pointer; color: var(--color-text-primary); }
.btn:hover { background: var(--color-background-secondary); }
.btn-primary { background: var(--color-text-primary); color: var(--color-background-primary); border-color: var(--color-text-primary); }
.btn-primary:hover { opacity: 0.82; }
.btn-sm { padding: 4px 10px; font-size: 12px; }
.btn-danger { border-color: #F09595; color: #A32D2D; }
.btn-danger:hover { background: #FCEBEB; }
.row { display: flex; gap: 8px; flex-wrap: wrap; align-items: flex-end; margin-bottom: 1rem; }
.field { display: flex; flex-direction: column; gap: 4px; }
.field label { font-size: 12px; color: var(--color-text-secondary); }
.inline-input { width: 68px; text-align: center; height: 26px; padding: 0 4px; font-size: 13px; border: 1px solid var(--color-border-primary); border-radius: 4px; background: var(--color-background-primary); color: var(--color-text-primary); }
.toast { position: fixed; bottom: 20px; right: 20px; background: var(--color-text-primary); color: var(--color-background-primary); padding: 10px 16px; border-radius: var(--border-radius-md); font-size: 13px; opacity: 0; transition: opacity 0.3s; pointer-events: none; z-index: 999; }
.toast.show { opacity: 1; }
</style>

<div class="app">
<h2 class="sr-only">R8ツアー ゴルフ管理アプリ</h2>
<div style="display:flex;align-items:baseline;gap:10px;margin-bottom:1.25rem;">
  <span style="font-size:20px;font-weight:500;">R8ツアー</span>
  <span style="font-size:13px;color:var(--color-text-secondary);">2025シーズン</span>
</div>

<div class="tabs">
  <button class="tab active" onclick="showTab('schedule',this)">スケジュール</button>
  <button class="tab" onclick="showTab('score',this)">スコア入力</button>
  <button class="tab" onclick="showTab('ranking',this)">ランキング</button>
  <button class="tab" onclick="showTab('members',this)">メンバー</button>
</div>

<!-- スケジュール -->
<div id="schedule" class="panel active">
  <div class="metric-grid">
    <div class="metric"><div class="metric-label">全ラウンド</div><div class="metric-value" id="m-total">10</div></div>
    <div class="metric"><div class="metric-label">完了</div><div class="metric-value" id="m-done">2</div></div>
    <div class="metric"><div class="metric-label">予定</div><div class="metric-value" id="m-upcoming">8</div></div>
    <div class="metric"><div class="metric-label">メンバー数</div><div class="metric-value" id="m-members">13</div></div>
  </div>
  <div class="card">
    <div class="sec">ラウンド一覧</div>
    <table><thead><tr><th>#</th><th>日付</th><th>コース</th><th>人数</th><th>プレー代</th><th>状態</th><th></th></tr></thead>
    <tbody id="sched-body"></tbody></table>
  </div>
  <div class="card">
    <div class="sec">ラウンドを追加</div>
    <div class="row">
      <div class="field"><label>日付</label><input type="text" id="new-date" placeholder="例: 8月10日（日）" style="width:150px;"></div>
      <div class="field"><label>コース名</label><input type="text" id="new-course" placeholder="コース名" style="width:180px;"></div>
      <div class="field"><label>プレー代</label><input type="text" id="new-fee" placeholder="例: 12,000円（昼食付）" style="width:170px;"></div>
      <div class="field"><label>人数</label><input type="number" id="new-players" placeholder="8" style="width:70px;" min="1" max="30"></div>
      <button class="btn btn-primary" onclick="addRound()">追加</button>
    </div>
  </div>
</div>

<!-- スコア入力 -->
<div id="score" class="panel">
  <div class="row">
    <div class="field"><label>ラウンドを選択</label>
      <select id="score-round" onchange="renderScoreInput()" style="width:240px;"></select>
    </div>
  </div>
  <div class="card">
    <div class="sec">スコアを入力して保存ボタンを押してください</div>
    <table><thead><tr><th>名前</th><th style="text-align:center;">スコア</th><th style="text-align:center;">参加</th></tr></thead>
    <tbody id="score-body"></tbody></table>
    <div style="margin-top:12px;display:flex;gap:8px;">
      <button class="btn btn-primary" onclick="saveScores()">保存</button>
      <button class="btn" onclick="markRoundDone()">このラウンドを完了にする</button>
    </div>
  </div>
</div>

<!-- ランキング -->
<div id="ranking" class="panel">
  <div class="row">
    <div class="field"><label>並び替え</label>
      <select id="rank-sort" onchange="renderRanking()" style="width:160px;">
        <option value="avg">平均スコア順</option>
        <option value="best">ベストスコア順</option>
        <option value="rounds">ラウンド数順</option>
      </select>
    </div>
  </div>
  <div class="card">
    <table><thead><tr><th>順位</th><th>名前</th><th>参加</th><th>平均</th><th>ベスト</th><th>ワースト</th></tr></thead>
    <tbody id="rank-body"></tbody></table>
  </div>
</div>

<!-- メンバー -->
<div id="members" class="panel">
  <div class="card">
    <div class="sec">メンバー一覧</div>
    <table><thead><tr><th>名前</th><th>参加回数</th><th>平均スコア</th><th>ベスト</th><th></th></tr></thead>
    <tbody id="member-body"></tbody></table>
  </div>
  <div class="card">
    <div class="sec">メンバーを追加</div>
    <div class="row">
      <div class="field"><label>氏名</label><input type="text" id="new-member" placeholder="例: 山田 太郎" style="width:160px;"></div>
      <button class="btn btn-primary" onclick="addMember()">追加</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
</div>

<script>
let state = {
  members: ['袴田 健一','中川 晃','笹川 和彦','三浦 卓也','桂木 能久','中村 英世','庄司 聡','加藤 勇樹','髙橋 渓太','二ツ森 友輝','小笠原 康晃','大湯 健介','樋口 颯士'],
  rounds: [
    {date:'3月28日（土）', course:'夏泊ゴルフリンクス', players:8, fee:'13,000円（昼食付）', done:true},
    {date:'4月18日（土）', course:'津軽高原ゴルフ場', players:8, fee:'12,100円（昼食付）', done:true},
    {date:'5月1日（金）', course:'津軽カントリークラブ', players:7, fee:'13,000円（昼食付）', done:false},
    {date:'5月2日（土）', course:'青森ロイヤルゴルフクラブ', players:8, fee:'未定', done:false},
    {date:'5月23日（土）', course:'青森カントリークラブ', players:8, fee:'12,495円（ロッカー・昼食別）', done:false},
    {date:'6月6日（土）', course:'青森ロイヤルゴルフクラブ', players:9, fee:'13,050円（昼食付）', done:false},
    {date:'6月21日（日）', course:'津軽高原ゴルフ場', players:8, fee:'14,900円 / 友の会12,400円（昼食別）', done:false},
    {date:'7月3日（金）', course:'びわの平ゴルフ倶楽部', players:10, fee:'11,000円（昼食付）', done:false},
    {date:'7月11日（土）', course:'津軽高原ゴルフ場', players:null, fee:'14,900円 / 友の会12,400円（昼食別）', done:false},
    {date:'7月19日（日）', course:'青森ロイヤルゴルフクラブ', players:null, fee:'13,050円（昼食付）', done:false},
  ],
  scores: [
    [null,100,null,null,97,null,90,108,133,96,131,109,null],
    [null,109,112,null,null,null,103,113,110,100,null,113,109],
    Array(13).fill(null),Array(13).fill(null),Array(13).fill(null),
    Array(13).fill(null),Array(13).fill(null),Array(13).fill(null),
    Array(13).fill(null),Array(13).fill(null),
  ]
};

function showTab(id, el) {
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
  if (id==='score') populateRoundSelect();
  if (id==='ranking') renderRanking();
  if (id==='members') renderMembers();
}

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

function getStats(mi) {
  const s = state.scores.map(row => row[mi]).filter(v => v !== null && v !== undefined);
  if (!s.length) return {rounds:0, avg:null, best:null, worst:null};
  return {
    rounds: s.length,
    avg: Math.round(s.reduce((a,b)=>a+b,0)/s.length*10)/10,
    best: Math.min(...s),
    worst: Math.max(...s)
  };
}

function renderSchedule() {
  const done = state.rounds.filter(r=>r.done).length;
  document.getElementById('m-total').textContent = state.rounds.length;
  document.getElementById('m-done').textContent = done;
  document.getElementById('m-upcoming').textContent = state.rounds.length - done;
  document.getElementById('m-members').textContent = state.members.length;
  document.getElementById('sched-body').innerHTML = state.rounds.map((r,i) => {
    const badge = r.done ? `<span class="badge b-green">完了</span>` : `<span class="badge b-blue">予定</span>`;
    return `<tr>
      <td style="color:var(--color-text-secondary);font-size:12px;">第${i+1}回</td>
      <td>${r.date}</td><td style="font-weight:500;">${r.course}</td>
      <td>${r.players ? r.players+'名' : '—'}</td>
      <td style="font-size:12px;color:var(--color-text-secondary);max-width:160px;white-space:normal;">${r.fee}</td>
      <td>${badge}</td>
      <td><button class="btn btn-sm btn-danger" onclick="deleteRound(${i})">削除</button></td>
    </tr>`;
  }).join('');
}

function addRound() {
  const date = document.getElementById('new-date').value.trim();
  const course = document.getElementById('new-course').value.trim();
  const fee = document.getElementById('new-fee').value.trim();
  const players = parseInt(document.getElementById('new-players').value) || null;
  if (!date || !course) { toast('日付とコース名は必須です'); return; }
  state.rounds.push({date, course, players, fee: fee||'未定', done:false});
  state.scores.push(Array(state.members.length).fill(null));
  document.getElementById('new-date').value='';
  document.getElementById('new-course').value='';
  document.getElementById('new-fee').value='';
  document.getElementById('new-players').value='';
  renderSchedule();
  toast('ラウンドを追加しました');
}

function deleteRound(i) {
  if (!confirm(`第${i+1}回（${state.rounds[i].course}）を削除しますか？`)) return;
  state.rounds.splice(i,1);
  state.scores.splice(i,1);
  renderSchedule();
  toast('削除しました');
}

function populateRoundSelect() {
  const sel = document.getElementById('score-round');
  sel.innerHTML = state.rounds.map((r,i)=>`<option value="${i}">第${i+1}回 — ${r.date} ${r.course}</option>`).join('');
  renderScoreInput();
}

function renderScoreInput() {
  const ri = parseInt(document.getElementById('score-round').value);
  const row = state.scores[ri] || [];
  document.getElementById('score-body').innerHTML = state.members.map((name, mi) => {
    const val = row[mi] !== null && row[mi] !== undefined ? row[mi] : '';
    return `<tr>
      <td style="font-weight:500;">${name}</td>
      <td style="text-align:center;">
        <input type="number" class="inline-input" data-mi="${mi}" value="${val}" placeholder="—" min="50" max="999" maxlength="3" style="width:72px;">
      </td>
      <td style="text-align:center;">
        <input type="checkbox" data-mi="${mi}" ${val!=='' ? 'checked' : ''} onchange="toggleParticipant(this,${ri})">
      </td>
    </tr>`;
  }).join('');

  document.querySelectorAll('#score-body input[type=number]').forEach(inp => {
    inp.addEventListener('input', () => {
      const mi = parseInt(inp.dataset.mi);
      const v = inp.value !== '' ? parseInt(inp.value) : null;
      if (!state.scores[ri]) state.scores[ri] = Array(state.members.length).fill(null);
      state.scores[ri][mi] = v;
      const cb = document.querySelector(`#score-body input[type=checkbox][data-mi="${mi}"]`);
      if (cb) cb.checked = v !== null;
    });
  });
}

function toggleParticipant(cb, ri) {
  const mi = parseInt(cb.dataset.mi);
  if (!cb.checked) {
    state.scores[ri][mi] = null;
    const inp = document.querySelector(`#score-body input[type=number][data-mi="${mi}"]`);
    if (inp) inp.value = '';
  }
}

function saveScores() {
  const ri = parseInt(document.getElementById('score-round').value);
  document.querySelectorAll('#score-body input[type=number]').forEach(inp => {
    const mi = parseInt(inp.dataset.mi);
    state.scores[ri][mi] = inp.value !== '' ? parseInt(inp.value) : null;
  });
  toast('スコアを保存しました');
}

function markRoundDone() {
  const ri = parseInt(document.getElementById('score-round').value);
  state.rounds[ri].done = true;
  renderSchedule();
  toast(`第${ri+1}回を完了にしました`);
}

function renderRanking() {
  const sort = document.getElementById('rank-sort').value;
  const stats = state.members.map((name,mi) => ({name, ...getStats(mi)})).filter(m=>m.rounds>0);
  stats.sort((a,b) => sort==='avg' ? a.avg-b.avg : sort==='best' ? a.best-b.best : b.rounds-a.rounds);
  document.getElementById('rank-body').innerHTML = stats.map((m,i) => {
    const rank = i===0?`<span class="rank-gold">1位</span>`:i===1?`<span class="rank-silver">2位</span>`:i===2?`<span class="rank-bronze">3位</span>`:`${i+1}位`;
    return `<tr><td>${rank}</td><td style="font-weight:500;">${m.name}</td><td>${m.rounds}回</td><td>${m.avg}</td><td style="color:#3B6D11;font-weight:500;">${m.best}</td><td style="color:#A32D2D;">${m.worst}</td></tr>`;
  }).join('');
}

function renderMembers() {
  document.getElementById('member-body').innerHTML = state.members.map((name,mi) => {
    const s = getStats(mi);
    return `<tr>
      <td style="font-weight:500;">${name}</td>
      <td>${s.rounds}回</td>
      <td>${s.avg !== null ? s.avg : '—'}</td>
      <td style="color:${s.best?'#3B6D11':'inherit'};font-weight:${s.best?'500':'400'};">${s.best !== null ? s.best : '—'}</td>
      <td><button class="btn btn-sm btn-danger" onclick="deleteMember(${mi})">削除</button></td>
    </tr>`;
  }).join('');
}

function addMember() {
  const name = document.getElementById('new-member').value.trim();
  if (!name) return;
  state.members.push(name);
  state.scores.forEach(row => row.push(null));
  document.getElementById('new-member').value = '';
  renderMembers();
  renderSchedule();
  toast(`${name} を追加しました`);
}

function deleteMember(mi) {
  if (!confirm(`${state.members[mi]} を削除しますか？`)) return;
  state.members.splice(mi, 1);
  state.scores.forEach(row => row.splice(mi, 1));
  renderMembers();
  renderSchedule();
  toast('メンバーを削除しました');
}

renderSchedule();
</script>
